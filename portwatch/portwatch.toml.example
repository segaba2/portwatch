# portwatch example configuration
# Copy this file to portwatch.toml and adjust as needed.

[general]
# Hosts to scan (IP addresses or hostnames)
hosts = ["127.0.0.1", "192.168.1.1"]

# Individual ports and/or ranges
ports = [22, 80, 443, "8000-8100"]

# Scan timeout per port in seconds
timeout = 1.0

# How often to run a scan (seconds)
interval = 300

# Where to persist state between runs
state_file = "/var/lib/portwatch/state.json"

# Where to write scan history
history_file = "/var/lib/portwatch/history.json"

[notifications]
# Set to false to disable all notifications
enabled = true

# Webhook URL (leave empty to disable)
webhook_url = ""

# Email settings (leave empty to disable)
[notifications.email]
smtp_host = "localhost"
smtp_port = 25
from_addr = "portwatch@example.com"
to_addrs = ["ops@example.com"]
subject_prefix = "[portwatch]"

[rate_limit]
# Maximum number of alerts per host within the time window
max_alerts = 5

# Sliding window size in seconds
window_seconds = 300

# How long (seconds) to suppress alerts after the limit is hit
cooldown_seconds = 60

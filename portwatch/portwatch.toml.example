# portwatch example configuration
# Copy to portwatch.toml and adjust as needed.

[portwatch]
# Hosts to scan (IP addresses or hostnames)
hosts = ["127.0.0.1", "192.168.1.1"]

# Ports to monitor — individual ports and/or ranges
ports = [22, 80, 443, "8000-8100"]

# Per-port connection timeout in seconds
timeout = 1.0

# How often to run a scan (seconds)
interval = 300

# Directory used to persist state and history between runs
state_dir = "/var/lib/portwatch"

# Maximum number of historical snapshots to keep per host
history_max_entries = 100

[portwatch.webhook]
# Leave url empty to disable webhook notifications
url = ""
# Optional bearer token sent in the Authorization header
token = ""

[portwatch.email]
# Leave to_addr empty to disable email notifications
to_addr = ""
from_addr = "portwatch@example.com"
smtp_host = "localhost"
smtp_port = 25
# Set to true to use STARTTLS
use_tls = false
# SMTP credentials (optional)
username = ""
password = ""

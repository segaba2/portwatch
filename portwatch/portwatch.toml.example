# portwatch configuration example
# Copy to portwatch.toml and adjust as needed.

[general]
# How often to scan, in seconds
interval = 300

# Where to store state files
state_dir = "~/.portwatch/state"

# Where to store history files
history_dir = "~/.portwatch/history"

# Where to store baseline snapshots
baseline_dir = "~/.portwatch/baselines"

[scan]
# Hosts to monitor (IP addresses or hostnames)
hosts = [
    "127.0.0.1",
    # "192.168.1.1",
]

# Ports to scan — individual ports and/or ranges
ports = [22, 80, 443, "8000-8100"]

# Per-port connection timeout in seconds
timeout = 1.0

# Transport protocols to scan
protocols = ["tcp"]

[baseline]
# Name of the active baseline to compare scans against.
# Leave empty to disable baseline comparison.
active = "production"

# Raise an alert when the scan deviates from the active baseline
alert_on_deviation = true

[webhook]
enabled = false
url = "https://hooks.example.com/portwatch"
# Optional Bearer token
# token = "secret"

[email]
enabled = false
smtp_host = "localhost"
smtp_port = 25
from_addr = "portwatch@example.com"
to_addrs = ["ops@example.com"]
# username = ""
# password = ""
# use_tls = false

[ratelimit]
# Maximum alerts per window
max_alerts = 5
# Window size in seconds
window_seconds = 3600

[retry]
max_attempts = 3
base_delay = 2.0
max_delay = 30.0

# portwatch example configuration
# Copy this file to portwatch.toml and adjust to your environment.

[portwatch]
# Hosts to scan (IP addresses or hostnames)
hosts = ["127.0.0.1", "192.168.1.1"]

# Ports to monitor. Supports individual ports and ranges.
ports = [22, 80, 443, "8000-8100"]

# Seconds to wait for a connection before marking a port as closed.
timeout = 1.0

# How often (in seconds) the daemon rescans all hosts.
interval = 300

# Directory where state snapshots and history are stored.
state_dir = "~/.local/share/portwatch"

# Maximum number of history entries to retain per host.
history_limit = 100

# Output format when using the `scan` CLI command: "text" or "json"
output_format = "text"

# Optional: write scan reports to this directory.
# report_dir = "/var/log/portwatch"

[portwatch.webhook]
# Set enabled = true and provide a URL to receive POST alerts.
enabled = false
url = "https://hooks.example.com/portwatch"
# Optional Bearer token sent in the Authorization header.
# token = "secret-token"

[portwatch.email]
# Set enabled = true to receive email alerts on port changes.
enabled = false
smtp_host = "smtp.example.com"
smtp_port = 587
use_tls = true
username = "alerts@example.com"
# password = "smtp-password"
from_addr = "alerts@example.com"
to_addrs = ["ops@example.com"]
subject_prefix = "[portwatch]"

# ---------------------------------------------------------------------------
# Scheduler tuning
# ---------------------------------------------------------------------------
[portwatch.scheduler]
# When the previous scan takes longer than *interval*, the next scan starts
# immediately (delay floor is 0). Set jitter > 0 to spread scans when
# multiple portwatch instances share the same target hosts.
jitter = 0.0

# portwatch configuration example
# Copy to portwatch.toml and adjust as needed.

[general]
# How often to run a scan (seconds)
interval = 300
# Path to store state between runs
state_file = "/var/lib/portwatch/state.json"
# Path to store scan history
history_file = "/var/lib/portwatch/history.json"

[scan]
# Hosts to monitor (IP addresses or hostnames)
hosts = ["127.0.0.1", "192.168.1.1"]
# Individual ports
ports = [22, 80, 443, 8080]
# Port ranges (inclusive)
port_ranges = [[3000, 3010]]
# Per-port connection timeout (seconds)
timeout = 1.0

[output]
# Report format: "text" or "json"
format = "text"
# Optional: write reports to this directory instead of stdout
# report_dir = "/var/log/portwatch/reports"

[webhook]
enabled = false
# url = "https://hooks.example.com/portwatch"
# secret = "changeme"

[email]
enabled = false
# smtp_host = "smtp.example.com"
# smtp_port = 587
# smtp_user = "alerts@example.com"
# smtp_password = "changeme"
# from_addr = "alerts@example.com"
# to_addrs = ["ops@example.com"]
